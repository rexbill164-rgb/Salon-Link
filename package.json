{
  "name": "webapp",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"const r={version:1,include:['/*'],exclude:['/static/*','/*.png','/*.ico','/*.jpg','/*.svg','/*.webp','/*.json','/manifest.json','/sw.js']};require('fs').writeFileSync('dist/_routes.json',JSON.stringify(r))\"",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "hono": "^4.12.10",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
